# OpusEngine .gitattributes.
# Default text auto-detect, normalised to LF in the repo. Override per
# extension when a tool needs a specific line ending or a file is
# actually binary.

* text=auto eol=lf

# .NET source / project / config
*.cs           text eol=lf diff=csharp
*.csx          text eol=lf diff=csharp
*.vb           text eol=lf
*.fs           text eol=lf
*.fsproj       text eol=lf
*.csproj       text eol=lf merge=union
*.vbproj       text eol=lf
*.props        text eol=lf merge=union
*.targets      text eol=lf merge=union
*.editorconfig text eol=lf
*.config       text eol=lf
*.resx         text eol=lf
*.ruleset      text eol=lf

# Solution files want CRLF on Windows so Visual Studio parses them cleanly.
*.sln          text eol=crlf merge=union

# Markup / data / docs
*.md           text eol=lf
*.markdown     text eol=lf
*.txt          text eol=lf
*.json         text eol=lf
*.json5        text eol=lf
*.jsonc        text eol=lf
*.xml          text eol=lf
*.yaml         text eol=lf
*.yml          text eol=lf
*.toml         text eol=lf
*.csv          text eol=lf
*.tsv          text eol=lf
*.html         text eol=lf
*.htm          text eol=lf
*.css          text eol=lf
*.scss         text eol=lf

# glTF JSON form is text; GLB binary form handled in the binary block.
*.gltf         text eol=lf

# POSIX shell scripts must stay LF so git bash and Linux runners execute.
*.sh           text eol=lf
*.bash         text eol=lf
*.zsh          text eol=lf

# Windows-native scripts must stay CRLF.
*.ps1          text eol=crlf
*.psm1         text eol=crlf
*.psd1         text eol=crlf
*.cmd          text eol=crlf
*.bat          text eol=crlf

Makefile       text eol=lf
makefile       text eol=lf
*.mk           text eol=lf

Dockerfile     text eol=lf
.gitattributes text eol=lf
.gitignore     text eol=lf
.gitmodules    text eol=lf

# Shader source
*.hlsl         text eol=lf
*.hlsli        text eol=lf
*.fx           text eol=lf
*.fxh          text eol=lf
*.glsl         text eol=lf
*.vert         text eol=lf
*.frag         text eol=lf
*.comp         text eol=lf
*.tesc         text eol=lf
*.tese         text eol=lf
*.geom         text eol=lf

